{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@loader/*": ["./engine/loader/*"],
      "@ioc/*": ["./engine/ioc/*"],
      "@builders/*": ["./engine/builders/*"],
      "@app/*": ["./engine/app/*"],
      "@engine/*": ["./engine/engine/*"],
      "@editor/*": ["./editor/*"],
      "@utils/*": ["./utils/*"]
    }
  }
}
