{
  "name": "@angelabc/ancadeba",
  "version": "1.0.0",
  "private": true,
  "description": "Ancadeba game engine monorepo",
  "keywords": [],
  "author": "AngelAbc",
  "license": "MPL-2.0",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @angelabc/ancadeba-web dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @angelabc/ancadeba-web build",
    "preview:web": "pnpm --filter @angelabc/ancadeba-web preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm -r lint",
    "typecheck": "tsc -b && tsc -p tsconfig.tests.json"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
