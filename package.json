{
    "name": "@angelabc/ancadeba",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "packages/engine",
        "packages/editor",
        "packages/shared"
    ],
    "description": "Game Engine",
    "keywords": [],
    "author": "AngelAbc",
    "license": "MPL-2.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently -n \"vite,tsc\" \"vite\" \"tsc -p packages/engine/tsconfig.json --noEmit --watch\"",
        "dev:editor": "concurrently -n \"vite,server,tsc\" \"vite --config packages/editor/vite.config.ts\" \"node packages/editor/server.ts\" \"tsc -p packages/editor/tsconfig.json --noEmit --watch\"",
        "test": "vitest run",
        "test:dev": "vitest watch",
        "lint": "eslint .",
        "build": "tsc -p packages/engine/tsconfig.json && vite build",
        "build:editor": "vite build --config packages/editor/vite.config.ts"
    },
    "devDependencies": {
        "@eslint/js": "^9.35.0",
        "@testing-library/react": "^16.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/node": "^24.2.1",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@typescript-eslint/eslint-plugin": "^8.40.0",
        "@typescript-eslint/parser": "^8.39.0",
        "@vitejs/plugin-react": "^5.0.1",
        "classnames": "^2.5.1",
        "concurrently": "^9.2.0",
        "cross-env": "^10.0.0",
        "dotenv": "^16.4.5",
        "eslint": "9.33.0",
        "express": "^5.1.0",
        "globals": "^16.3.0",
        "jsdom": "^26.1.0",
        "react": "^18.3.1",
        "react-icons": "^5.5.0",
        "typescript": "^5.9.2",
        "vite": "^7.1.3",
        "vite-plugin-static-copy": "^3.1.1",
        "vitest": "^3.2.4"
    }
}
