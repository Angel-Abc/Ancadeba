    "license": "MPL-2.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently -n \"vite,tsc\" \"vite\" \"tsc --noEmit --watch\"",
        "dev:editor": "concurrently -n \"vite,server\" \"vite --config editor/vite.config.ts\" \"node editor/server.ts\"",
        "test": "vitest run",
        "test:dev": "vitest watch",
        "lint": "eslint .",
        "build": "tsc && vite build",
        "build:editor": "vite build --config editor/vite.config.ts"
    },
    "devDependencies": {
        "@eslint/js": "^9.32.0",
        "@testing-library/react": "^16.0.0",
        "@types/express": "^5.0.3",
        "@types/node": "^24.2.1",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@typescript-eslint/eslint-plugin": "^8.39.0",
        "@typescript-eslint/parser": "^8.39.0",
        "@vitejs/plugin-react": "^4.3.1",
        "concurrently": "^9.2.0",
        "cross-env": "^10.0.0",
        "eslint": "9.33.0",
        "express": "^5.1.0",
        "globals": "^16.3.0",
        "jsdom": "^26.1.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-icons": "^5.5.0",
        "typescript": "^5.9.2",
        "vite": "^7.1.1",
        "vite-plugin-static-copy": "^3.1.1",
        "vitest": "^3.2.4",
        "zod": "^4.0.17"
    }
}
